# Force all text files to use LF line endings in repo
* text eol=lf

# Shell scripts must be LF
*.sh text eol=lf

# Python also should be LF
*.py text eol=lf

# Windows batch files should stay CRLF
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf

# Prevent conversion on binary files
*.png binary
*.jpg binary
*.zip binary
*.exe binary
*.dll binary